# ── AI 服务凭证配置 ───────────────────────────────────────────────────────────
# 复制本文件为 .env.local 并填写真实值

# API 鉴权 Token（必填）
# 使用 Anthropic 官方服务：填写 sk-ant-xxx
# 使用 DeepSeek 兼容服务：填写 DeepSeek API Key
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# API Base URL（使用第三方兼容服务时填写，使用官方 Anthropic 可留空）
# DeepSeek 兼容端点示例：https://api.deepseek.com/anthropic
# OpenAI 兼容端点示例：https://api.openai.com/v1
ANTHROPIC_BASE_URL=

# 使用的模型（必填）
# Anthropic 官方：claude-opus-4-5 | claude-sonnet-4-5-20250929 | claude-haiku-4-5
# DeepSeek：deepseek-chat | deepseek-reasoner
ANTHROPIC_MODEL=deepseek-chat

# 以下两项供部分 SDK 内部路由使用，设为相同模型即可
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-chat
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-chat
